# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
# Railway injects these automatically in production.
# For local development, use docker-compose defaults below.
DATABASE_URL=postgresql+asyncpg://dev:dev@localhost:5432/quant_futures

# --- Data Fetcher ---
FETCH_INSTRUMENTS=NQ,ES,YM,RTY
FETCH_OVERLAP_DAYS=7
# Cron: weekdays at 18:00 UTC (after US market close)
FETCH_CRON=0 18 * * 1-5

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated allowed origins for CORS (frontend URL in production)
CORS_ORIGINS=http://localhost:3000

# --- Security ---
# Generate with: openssl rand -hex 32
API_SECRET_KEY=changeme

# --- Period 3: IBKR (not needed until live trading) ---
# IBKR_HOST=
# IBKR_PORT=4003
# IBKR_CLIENT_ID=1
